      'Eco-Ficción': 'Relación entre colapso ambiental y recomposición social. Plantea qué modelo de vida merece continuar.',
      Zombie: 'Amenaza masiva + dilemas de comunidad. El verdadero conflicto suele ser humano y ético.',
      Wasteland: 'Territorio hostil, facciones y ley de escasez. Ideal para viajes, trueque, deuda y poder local.',
      'Caída de la Sociedad': 'Momento de ruptura sistémica y transición al nuevo orden. Tensión entre memoria y adaptación.'
    },
    superheroes: {
      Vigilante: 'Justicia por fuera del sistema. El eje dramático es la frontera entre reparación y abuso de poder.',
      'Épica Cósmica': 'Escala universal con amenazas mayores al individuo. Mantén ancla emocional para no perder cercanía.',
      Deconstrucción: 'Cuestiona mitos del héroe clásico: propaganda, trauma, responsabilidad y daño colateral.',
      Origen: 'Nacimiento del héroe a través de error, pérdida o hallazgo. Define valores y límites desde el inicio.',
      Crossover: 'Cruce de personajes/facciones con agendas distintas. El reto es equilibrio de voces y objetivos.'
    },
    musical: {
      Broadway: 'Estructura teatral con números que avanzan conflicto y carácter. Canción = decisión dramática.',
      'Ópera Rock': 'Narrativa intensa y estilizada guiada por energía musical. Útil para identidades en choque.',
      Jukebox: 'Canciones preexistentes recontextualizadas. La selección debe dialogar con arco emocional y tema.',
      'Cine Musical': 'Lenguaje audiovisual + partitura narrativa. Coreografía y puesta en escena cuentan historia.',
      Diegético: 'La música existe dentro del mundo narrativo. Refuerza realismo del personaje y su entorno.'
    },
    deportivo: {
      'Drama de Redención': 'Caída y regreso del atleta. El arco exige costo, disciplina y transformación real.',
      Competición: 'Rivalidad y preparación hacia un objetivo concreto. Ritmo, táctica y presión sostienen la tensión.',
      Torneo: 'Progresión por fases con escalada de dificultad. Cada ronda debe redefinir estrategia y autoestima.',
      Underdog: 'Protagonista subestimado frente a sistema adverso. El triunfo es técnico, mental y colectivo.',
      'Biografía Deportiva': 'Vida de atleta con contexto social e histórico. Importa tanto la cancha como el afuera.'
    }
  };

  const byGenre = guides[genreId] || {};
  if (byGenre[subgenre]) return byGenre[subgenre];
  return `${subgenre}: variante de ${genreId.replace(/-/g, ' ')} para explorar conflicto, tono y ritmo desde otra perspectiva narrativa.`;
}

function applyAuroraTheme(genre) {
  if (!genre) return;
  if (window.NodiaAuroraThemeComponent?.apply) {
    window.NodiaAuroraThemeComponent.apply(genre);
    return;
  }

  // Fallback antifallas si el componente no cargó.
  try {
    window.NodiaGenreOrnaments?.setGenre?.(genre.id);
  } catch (error) {
    console.warn('[lobby] set ornaments failed', error);
  }

}

// ── NAVIGATION & PREMIUM ACTIONS ──
// (navLinks click handler is registered above in a WebView-safe way)
actionBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    actionBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    THEME_CLASSES.forEach(themeClass => document.body.classList.remove(themeClass));
    document.body.classList.add(`theme-${btn.dataset.action}`);
    switchPanel(btn.dataset.action);
    applyWorldHero();
  });
});

function switchPanel(actionId) {
  if (uiFx?.switchPanelWithTransition) {
    const handled = uiFx.switchPanelWithTransition('.options-panel', actionId);
    if (handled) return;
  }
  optionsPanels.forEach((panel) => panel.classList.remove('active'));
  document.getElementById(`panel-${actionId}`)?.classList.add('active');
}

function switchWorld(worldId) {
  const world = WORLDS[worldId];
  if (!world) return;
  currentWorld = worldId;
  if (portalImg) portalImg.src = world.img;
  if (worldName) worldName.textContent = world.name;
  if (worldSub) worldSub.innerHTML = world.subtitle;
  updateWorldContext(world);
