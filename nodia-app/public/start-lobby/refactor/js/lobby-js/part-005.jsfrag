      conflict: 'Supervivencia del grupo frente a pérdida progresiva.',
      promise: 'Intensidad, estrategia y memoria del trauma.'
    },
    'post-apocaliptico': {
      core: 'Reconstrucción de sentido tras el colapso del sistema.',
      conflict: 'Escasez, poder local y nuevas reglas de convivencia.',
      promise: 'Supervivencia con reflexión social y emocional.'
    },
    superheroes: {
      core: 'Poder extraordinario enfrentado a fragilidad humana.',
      conflict: 'Identidad secreta, responsabilidad y daño colateral.',
      promise: 'Espectáculo con dilema moral contemporáneo.'
    },
    musical: {
      core: 'La música expresa lo que el diálogo no alcanza.',
      conflict: 'Deseo interno versus máscara social.',
      promise: 'Ritmo dramático, emoción elevada y momentos icónicos.'
    },
    deportivo: {
      core: 'Disciplina, equipo y crecimiento bajo metas competitivas.',
      conflict: 'Talento versus constancia, ego versus cooperación.',
      promise: 'Superación, momentum y recompensa emocional.'
    }
  };
  const fallback = {
    core: 'Historia con identidad temática clara.',
    useCase: 'Un dilema que obligue al personaje a cambiar.',
    promise: 'Una experiencia narrativa consistente y memorable.',
    avoid: 'Evita clichés sin conflicto emocional y decisiones sin consecuencias.'
  };
  const resolved = info[genreId] || fallback;
  if (!resolved.useCase && resolved.conflict) resolved.useCase = resolved.conflict;
  if (!resolved.avoid) resolved.avoid = 'Evita escenas decorativas sin decisión narrativa ni evolución del personaje.';
  return resolved;
}

function simplifyCharacterName(name) {
  const text = String(name || '').trim();
  if (!text) return '';
  return text
    .replace(/\s{2,}/g, ' ')
    .replace(/([A-Za-zÁÉÍÓÚÑáéíóúñ]+)\s+\1$/i, '$1');
}

function getSubgenreGuide(genreId, subgenre) {
  const guides = {
    fantasia: {
