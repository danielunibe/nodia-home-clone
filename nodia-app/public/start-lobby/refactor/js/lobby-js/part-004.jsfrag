  const subFocusIcon = document.getElementById('subgenreFocusIcon');
  const subFocusCard = document.getElementById('subgenreFocusCard');
  const tagsList = document.getElementById('genre-tags');
  if (tagsList) {
    tagsList.querySelectorAll('.genre-tag-chip').forEach((chip) => {
      chip.classList.toggle('is-active', chip === activeChip);
    });
  }
  if (subFocusTitle) subFocusTitle.textContent = subgenre || 'Subgénero';
  if (subFocusText) subFocusText.textContent = guide || '';
  if (subFocusIcon) subFocusIcon.innerHTML = genre?.seal ? genre.seal : '✦';
  if (subFocusCard) {
    subFocusCard.style.borderColor = hexToAlpha(genre?.dominantColor || '#C5A367', 0.4);
    subFocusCard.style.boxShadow = `0 10px 24px rgba(0,0,0,0.24), 0 0 16px ${hexToAlpha(genre?.dominantColor || '#C5A367', 0.18)}`;
  }
}

