* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --bg: #050507;
  --text: #e8e6e1;
  --text-2: #9a958e;
  --text-3: #7a7266;
  --gold: #c9a66b;
  --gold-light: #e0c38e;
  --card: rgba(255, 255, 255, 0.04);
  --border: rgba(255, 255, 255, 0.08);
  --hover: rgba(255, 255, 255, 0.06);
}

body {
  min-height: 100vh;
  overflow-x: hidden;
  background: var(--bg);
  color: var(--text);
  font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  -webkit-font-smoothing: antialiased;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  background:
    radial-gradient(900px 700px at 50% -20%, rgba(110, 65, 165, 0.28), transparent 60%),
    radial-gradient(700px 500px at 85% 15%, rgba(201, 166, 107, 0.09), transparent 65%),
    radial-gradient(800px 600px at 15% 85%, rgba(70, 45, 120, 0.18), transparent 60%),
    radial-gradient(ellipse at center, #0a080d 0%, #050507 70%);
  transition: background 0.6s cubic-bezier(0.2, 0, 0, 1);
}

body[data-world="ethyria"]::before {
  background:
    radial-gradient(900px 700px at 50% -20%, rgba(110, 65, 165, 0.28), transparent 60%),
    radial-gradient(700px 500px at 85% 15%, rgba(201, 166, 107, 0.09), transparent 65%),
    radial-gradient(800px 600px at 15% 85%, rgba(70, 45, 120, 0.18), transparent 60%),
    radial-gradient(ellipse at center, #0a080d 0%, #050507 70%);
}

body[data-world="nuevo"]::before {
  background:
    radial-gradient(900px 700px at 50% -20%, rgba(62, 130, 190, 0.24), transparent 60%),
    radial-gradient(700px 500px at 85% 15%, rgba(120, 194, 220, 0.13), transparent 65%),
    radial-gradient(800px 600px at 12% 82%, rgba(30, 95, 125, 0.2), transparent 62%),
    radial-gradient(ellipse at center, #05101a 0%, #05090d 70%);
}

body[data-world="idea"]::before {
  background:
    radial-gradient(900px 700px at 50% -20%, rgba(188, 84, 128, 0.22), transparent 60%),
    radial-gradient(700px 500px at 85% 15%, rgba(235, 148, 98, 0.15), transparent 65%),
    radial-gradient(780px 560px at 15% 85%, rgba(120, 42, 68, 0.22), transparent 60%),
    radial-gradient(ellipse at center, #140910 0%, #0a060a 72%);
}

button,
a {
  font: inherit;
}

.stars {
  position: fixed;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  opacity: 0.5;
  background-image:
    radial-gradient(1px 1px at 15% 20%, rgba(255, 255, 255, 0.3), transparent),
    radial-gradient(1px 1px at 35% 15%, rgba(255, 255, 255, 0.2), transparent),
    radial-gradient(1px 1px at 65% 25%, rgba(255, 255, 255, 0.25), transparent),
    radial-gradient(1px 1px at 80% 40%, rgba(255, 255, 255, 0.2), transparent),
    radial-gradient(1px 1px at 25% 60%, rgba(255, 255, 255, 0.15), transparent),
    radial-gradient(1px 1px at 75% 70%, rgba(255, 255, 255, 0.2), transparent),
    radial-gradient(1px 1px at 45% 85%, rgba(255, 255, 255, 0.25), transparent),
    radial-gradient(1px 1px at 90% 20%, rgba(201, 166, 107, 0.4), transparent),
    radial-gradient(1px 1px at 10% 80%, rgba(201, 166, 107, 0.3), transparent);
  transition: opacity 0.45s ease, filter 0.45s ease;
}

body[data-world="ethyria"] .stars {
  opacity: 0.5;
  filter: hue-rotate(0deg) saturate(1);
}

body[data-world="nuevo"] .stars {
  opacity: 0.62;
  filter: hue-rotate(180deg) saturate(1.1);
}

body[data-world="idea"] .stars {
  opacity: 0.58;
  filter: hue-rotate(315deg) saturate(1.2);
}

.app {
  position: relative;
  z-index: 2;
  display: flex;
  min-height: 100vh;
  flex-direction: column;
}

/* Header */

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
  padding: 28px 48px;
}

.brand {
  display: flex;
  min-width: 240px;
  align-items: center;
  gap: 14px;
}

.logo {
  position: relative;
  display: grid;
  width: 44px;
  height: 44px;
  place-items: center;
  border: 1px solid rgba(201, 166, 107, 0.25);
  border-radius: 12px;
  background: linear-gradient(135deg, #1a1611 0%, #2a241c 100%);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.05),
    0 4px 12px rgba(0, 0, 0, 0.4);
}

.logo::before {
  content: "";
  width: 22px;
  height: 22px;
  border: 2px solid var(--gold);
  border-radius: 4px;
  opacity: 0.9;
  transform: rotate(45deg);
}

.logo::after {
  content: "";
  position: absolute;
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: var(--gold);
}

.brand-text h1 {
  color: #f0ede7;
  font-size: 22px;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 2.5px;
}

.brand-text p {
  margin-top: 3px;
  color: var(--text-3);
  font-size: 11px;
  letter-spacing: 0.3px;
}

.header-pill {
  padding: 9px 20px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: var(--card);
  backdrop-filter: blur(16px);
  color: #b9b3a9;
  font-size: 13px;
  letter-spacing: 0.2px;
  white-space: nowrap;
}

.nav {
  display: flex;
  gap: 32px;
  color: var(--text-2);
  font-size: 14px;
}

.nav a {
  color: inherit;
  text-decoration: none;
  transition: color 0.2s ease;
}

.nav a:hover {
  color: var(--text);
}

/* Main */

.main {
  display: grid;
  flex: 1;
  grid-template-columns: 45% 55%;
  align-items: center;
  width: 100%;
  max-width: 1600px;
  margin: 0 auto;
  gap: 48px;
  padding: 24px 48px 120px;
}

.left {
  padding-top: 12px;
}

.meta-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 28px;
}

.meta-pill {
  padding: 6px 12px;
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(8px);
  color: #c8c3bc;
  font-size: 12px;
}

.meta-pill:first-child {
  border-color: rgba(201, 166, 107, 0.25);
  background: rgba(201, 166, 107, 0.12);
  color: var(--gold-light);
}

.greeting {
  color: var(--text-2);
  font-size: 15px;
  line-height: 1.5;
}

.greeting strong {
  display: block;
  color: var(--text);
  font-size: 16px;
  font-weight: 500;
}

.gold-line {
  width: 56px;
  height: 2px;
  margin: 18px 0 32px;
  opacity: 0.8;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}

.hero-title {
  margin-bottom: 18px;
  color: #f2efe9;
  font-family: "Playfair Display", Georgia, serif;
  font-size: clamp(40px, 4.2vw, 52px);
  font-weight: 500;
  line-height: 1.05;
  letter-spacing: -0.5px;
}

.hero-sub {
  max-width: 520px;
  color: var(--text-2);
  font-size: 16px;
  line-height: 1.65;
}

.world-actions {
  display: flex;
  max-width: 520px;
  flex-direction: column;
  gap: 12px;
  margin-top: 44px;
}

.world-option {
  position: relative;
  display: flex;
  width: 100%;
  align-items: center;
  gap: 16px;
  overflow: hidden;
  padding: 18px 20px;
  border: 1px solid var(--border);
  border-radius: 18px;
  background: var(--card);
  backdrop-filter: blur(16px);
  cursor: pointer;
  text-align: left;
  transition: all 0.35s cubic-bezier(0.2, 0, 0, 1);
}

.world-option::before {
  content: "";
  position: absolute;
  inset: 0;
  opacity: 0;
  background: radial-gradient(400px 100px at left, rgba(255, 255, 255, 0.05), transparent);
  transition: opacity 0.3s ease;
}

.world-option:hover {
  border-color: rgba(255, 255, 255, 0.14);
  background: var(--hover);
}

.world-option:hover::before {
  opacity: 1;
}

.world-option.active {
  border-color: var(--gold);
  background: var(--gold);
  box-shadow:
    0 8px 30px rgba(201, 166, 107, 0.22),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
  transform: none;
}

.option-icon {
  z-index: 1;
  display: grid;
  width: 42px;
  height: 42px;
  flex-shrink: 0;
  place-items: center;
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 12px;
  background: rgba(0, 0, 0, 0.25);
  transition: all 0.3s ease;
}

.world-option.active .option-icon {
  border-color: rgba(0, 0, 0, 0.15);
  background: rgba(0, 0, 0, 0.18);
}

.option-icon svg {
  width: 20px;
  height: 20px;
  fill: none;
  stroke: var(--text-2);
  stroke-width: 1.5;
}

.world-option.active .option-icon svg {
  stroke: #1a140c;
}

.option-text {
  z-index: 1;
  flex: 1;
}

.option-title {
  color: var(--text);
  font-size: 16px;
  font-weight: 500;
  letter-spacing: 0.1px;
}

.world-option.active .option-title {
  color: #0d0a06;
}

.option-sub {
  margin-top: 3px;
  color: var(--text-2);
  font-size: 13px;
}

.world-option.active .option-sub {
  color: rgba(0, 0, 0, 0.65);
}

.templates {
  margin-top: 26px;
}

.templates-label {
  margin-bottom: 12px;
  color: var(--text-3);
  font-size: 12px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.template-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.template-pill {
  padding: 8px 14px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: var(--card);
  backdrop-filter: blur(8px);
  color: #b8b2a8;
  cursor: pointer;
  font-size: 13px;
  transition: all 0.2s ease;
}

.template-pill:hover {
  border-color: rgba(255, 255, 255, 0.15);
  background: var(--hover);
  color: var(--text);
}

.saved-projects {
  margin-top: 20px;
}

.project-shelf {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  max-width: 620px;
}

.project-card {
  display: flex;
  flex-direction: column;
  gap: 4px;
  text-align: left;
  padding: 12px 14px;
  border-radius: 14px;
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.04);
  color: #d6d1c8;
  cursor: pointer;
  transition: all 0.25s ease;
}

.project-card strong {
  font-size: 14px;
  font-weight: 600;
  color: #f0ede7;
}

.project-card span {
  font-size: 12px;
  color: #9f998f;
}

.project-card:hover {
  border-color: rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.08);
}

.project-card.active {
  border-color: rgba(201, 166, 107, 0.6);
  background: rgba(201, 166, 107, 0.18);
}

.project-card.new {
  border-style: dashed;
}

/* Right visual */

.right {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 20px;
}

.world-stage {
  position: relative;
  display: grid;
  width: 500px;
  height: 500px;
  place-items: center;
}

.rings {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
}

.ring {
  position: absolute;
  border: 1px solid;
  border-radius: 50%;
}

.ring::before {
  content: "";
  position: absolute;
  top: -3px;
  left: 50%;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--gold);
  box-shadow:
    0 0 12px rgba(201, 166, 107, 0.8),
    0 0 24px rgba(201, 166, 107, 0.4);
  transform: translateX(-50%);
}

.ring-1 {
  width: 380px;
  height: 380px;
  border-color: rgba(201, 166, 107, 0.22);
  animation: spin 140s linear infinite;
}

.ring-2 {
  width: 440px;
  height: 440px;
  border-color: rgba(201, 166, 107, 0.14);
  animation: spin-reverse 110s linear infinite;
}

.ring-2::before {
  top: -2px;
  width: 4px;
  height: 4px;
  opacity: 0.8;
  background: var(--gold-light);
}

.ring-3 {
  width: 500px;
  height: 500px;
  border-color: rgba(201, 166, 107, 0.08);
  animation: spin 180s linear infinite;
}

.ring-3::before {
  top: -1.5px;
  width: 3px;
  height: 3px;
  opacity: 0.6;
}

.rings.pulse .ring-1 {
  animation-duration: 20s;
}

.rings.pulse .ring-2 {
  animation-duration: 16s;
}

.rings.pulse .ring-3 {
  animation-duration: 24s;
}

/* CSS-only replacement for base64 images */

.world-circle {
  position: relative;
  width: 340px;
  height: 340px;
  overflow: hidden;
  border: 1px solid rgba(201, 166, 107, 0.18);
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 45%, #1a1510 0%, #0f0c08 40%, #050507 100%);
  box-shadow:
    inset 0 0 80px rgba(0, 0, 0, 0.9),
    inset 0 0 40px rgba(0, 0, 0, 0.6),
    0 0 120px rgba(201, 166, 107, 0.08),
    0 40px 80px rgba(0, 0, 0, 0.7);
  transition:
    opacity 0.45s cubic-bezier(0.4, 0, 0.2, 1),
    transform 0.45s cubic-bezier(0.4, 0, 0.2, 1),
    filter 0.45s cubic-bezier(0.4, 0, 0.2, 1);
}

.world-circle::after {
  content: "";
  position: absolute;
  inset: -2px;
  z-index: 6;
  border-radius: 50%;
  padding: 2px;
  background: conic-gradient(
    from 210deg,
    transparent 0deg,
    rgba(201, 166, 107, 0.3) 60deg,
    transparent 120deg,
    transparent 360deg
  );
  -webkit-mask:
    linear-gradient(#000 0 0) content-box,
    linear-gradient(#000 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  animation: spin 24s linear infinite;
}

.world-circle.changing {
  opacity: 0.92;
  filter: blur(1.2px);
  transform: none;
}

.world-sky {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 50% 42%, rgba(255, 220, 150, 0.75), transparent 7%),
    radial-gradient(circle at 48% 36%, rgba(156, 94, 208, 0.36), transparent 26%),
    linear-gradient(180deg, #161a32 0%, #2f1d38 48%, #a65d31 100%);
}

.world-sun {
  position: absolute;
  z-index: 2;
  top: 43%;
  left: 50%;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: #ffdca0;
  box-shadow:
    0 0 24px rgba(255, 220, 160, 0.9),
    0 0 80px rgba(201, 166, 107, 0.36);
  transform: translate(-50%, -50%);
}

.world-mountain {
  position: absolute;
  right: -12%;
  bottom: 0;
  left: -12%;
  clip-path: polygon(
    0 68%,
    8% 45%,
    18% 61%,
    28% 34%,
    41% 60%,
    50% 40%,
    61% 64%,
    73% 36%,
    87% 58%,
    100% 42%,
    100% 100%,
    0 100%
  );
}

.world-mountain-back {
  height: 50%;
  background: rgba(35, 31, 48, 0.72);
  transform: translateY(-10%);
}

.world-mountain-mid {
  height: 45%;
  background: rgba(13, 17, 31, 0.84);
  transform: translateY(6%);
}

.world-mountain-front {
  height: 40%;
  background: rgba(5, 8, 14, 0.95);
  transform: translateY(18%);
}

.world-glow {
  position: absolute;
  inset: 0;
  z-index: 5;
  background:
    radial-gradient(circle at center, transparent 45%, rgba(0, 0, 0, 0.45) 100%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent 28%);
}

/* State variations */

.world-ethyria .world-sky {
  background:
    radial-gradient(circle at 50% 42%, rgba(255, 220, 150, 0.72), transparent 7%),
    radial-gradient(circle at 48% 36%, rgba(156, 94, 208, 0.34), transparent 26%),
    linear-gradient(180deg, #161a32 0%, #2f1d38 48%, #a65d31 100%);
}

.world-nuevo .world-sky {
  background:
    radial-gradient(circle at 46% 39%, rgba(180, 235, 255, 0.78), transparent 8%),
    radial-gradient(circle at 55% 28%, rgba(90, 160, 210, 0.28), transparent 28%),
    linear-gradient(180deg, #0e2530 0%, #17334a 50%, #46616d 100%);
}

.world-idea .world-sky {
  background:
    radial-gradient(circle at 55% 45%, rgba(255, 220, 140, 0.78), transparent 7%),
    radial-gradient(circle at 48% 30%, rgba(255, 130, 94, 0.32), transparent 30%),
    linear-gradient(180deg, #241328 0%, #4b1c30 48%, #b35a32 100%);
}

.world-info {
  margin-top: 28px;
  text-align: center;
}

.world-eyebrow {
  margin-bottom: 10px;
  color: var(--text-3);
  font-size: 12px;
  letter-spacing: 1.4px;
  text-transform: uppercase;
}

.world-title {
  color: #f1ede6;
  font-family: "Playfair Display", Georgia, serif;
  font-size: 38px;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 3px;
}

.world-subtitle {
  margin-top: 8px;
  color: var(--text-2);
  font-size: 14px;
}

.info-card {
  width: 100%;
  max-width: 500px;
  margin-top: 20px;
  padding: 22px 26px 20px;
  border: 1px solid var(--border);
  border-radius: 20px;
  background: rgba(12, 10, 8, 0.55);
  backdrop-filter: blur(24px);
  box-shadow:
    0 20px 60px rgba(0, 0, 0, 0.5),
    inset 0 1px 0 rgba(255, 255, 255, 0.04);
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px;
}

.info-item label {
  display: block;
  margin-bottom: 6px;
  color: var(--text-3);
  font-size: 11px;
  letter-spacing: 0.9px;
  text-transform: uppercase;
}

.info-item .value {
  color: var(--text);
  font-size: 14.5px;
  font-weight: 500;
}

.progress-wrap {
  grid-column: 1 / -1;
  margin-top: 20px;
}

.progress-track {
  position: relative;
  height: 4px;
  overflow: hidden;
  border-radius: 2px;
  background: rgba(255, 255, 255, 0.07);
}

.progress-fill {
  position: relative;
  width: 65%;
  height: 100%;
  border-radius: 2px;
  background: linear-gradient(90deg, var(--gold), var(--gold-light));
  box-shadow: 0 0 14px rgba(201, 166, 107, 0.5);
  transition: width 0.8s cubic-bezier(0.2, 0, 0, 1);
}

.progress-fill::after {
  content: "";
  position: absolute;
  top: 50%;
  right: 0;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--gold-light);
  box-shadow: 0 0 10px rgba(201, 166, 107, 0.8);
  transform: translateY(-50%);
}

/* Command Bar */

.command-bar {
  position: fixed;
  bottom: 26px;
  left: 50%;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 24px;
  padding: 12px 18px 12px 20px;
  border: 1px solid var(--border);
  border-radius: 16px;
  background: rgba(10, 8, 6, 0.62);
  backdrop-filter: blur(24px) saturate(1.2);
  box-shadow:
    0 16px 50px rgba(0, 0, 0, 0.6),
    inset 0 1px 0 rgba(255, 255, 255, 0.04);
  color: #9a9489;
  font-size: 13px;
  white-space: nowrap;
  transform: translateX(-50%);
}

.cmd-hint {
  display: flex;
  align-items: center;
  gap: 8px;
}

.cmd-hint kbd {
  padding: 3px 6px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 6px;
  background: rgba(255, 255, 255, 0.08);
  color: var(--text);
  font-family: "Inter", monospace;
  font-size: 11px;
}

.cmd-shortcuts {
  display: flex;
  align-items: center;
  gap: 14px;
  padding-left: 20px;
  border-left: 1px solid rgba(255, 255, 255, 0.08);
}

.shortcut {
  display: flex;
  align-items: center;
  gap: 6px;
  color: #b7b1a8;
  cursor: default;
  transition: color 0.2s ease;
}

.shortcut:hover {
  color: var(--text);
}

.shortcut-icon {
  display: grid;
  width: 22px;
  height: 22px;
  place-items: center;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 6px;
  background: rgba(255, 255, 255, 0.06);
}

/* Animations */

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

@keyframes spin-reverse {
  to {
    transform: rotate(-360deg);
  }
}

/* Responsive */

@media (max-width: 1280px) {
  .main {
    grid-template-columns: 1.1fr 0.9fr;
    gap: 32px;
    padding: 24px 32px 120px;
  }

  .header {
    padding: 24px 32px;
  }

  .project-shelf {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 1024px) {
  .header-pill {
    display: none;
  }

  .main {
    grid-template-columns: 1fr;
    gap: 60px;
  }

  .left {
    order: 2;
    padding-top: 0;
  }

  .right {
    order: 1;
  }

  .hero-title {
    font-size: 48px;
  }

  .world-actions {
    max-width: none;
  }

  .command-bar {
    display: none;
  }
}

@media (max-width: 640px) {
  .header {
    flex-wrap: wrap;
    padding: 20px;
  }

  .nav {
    display: none;
  }

  .main {
    padding: 12px 20px 40px;
  }

  .world-stage {
    width: 340px;
    height: 340px;
    transform: scale(0.9);
  }

  .ring-1 {
    width: 280px;
    height: 280px;
  }

  .ring-2 {
    width: 330px;
    height: 330px;
  }

  .ring-3 {
    width: 380px;
    height: 380px;
  }

  .world-circle {
    width: 260px;
    height: 260px;
  }

  .world-title {
    font-size: 34px;
    letter-spacing: 2px;
  }

  .info-card {
    padding: 18px 20px;
  }

  .info-grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .hero-title {
    font-size: 40px;
  }
}

/* New cinematic inner world (code-only, no images) */
.world-circle {
  position: relative;
  overflow: hidden;
  border-radius: 999px;
  background: #11142a;
  box-shadow:
    inset 0 0 120px rgba(0, 0, 0, 0.9),
    inset 0 0 34px rgba(255, 255, 255, 0.035),
    0 34px 100px rgba(0, 0, 0, 0.72);
  animation: world-breathe 8s ease-in-out infinite;
}

.sky-base { position: absolute; inset: 0; background:
  radial-gradient(circle at 50% 43%, rgba(255, 219, 154, 0.78), transparent 6%),
  radial-gradient(circle at 50% 37%, rgba(129, 88, 190, 0.44), transparent 30%),
  linear-gradient(180deg, #141735 0%, #2f1f3e 45%, #754045 66%, #9d5737 100%); }

.sky-aurora { position: absolute; inset: -20%; mix-blend-mode: screen; filter: blur(22px); opacity: 0.42; }
.aurora-a { background: radial-gradient(ellipse at 34% 38%, rgba(122, 92, 212, 0.24), transparent 38%); animation: aurora-a 18s ease-in-out infinite alternate; }
.aurora-b { background: radial-gradient(ellipse at 70% 48%, rgba(255, 143, 92, 0.18), transparent 34%); animation: aurora-b 21s ease-in-out infinite alternate; }
.aurora-c { background: radial-gradient(ellipse at 48% 62%, rgba(255, 206, 132, 0.11), transparent 40%); animation: aurora-c 24s ease-in-out infinite alternate; }

.inner-stars { position: absolute; inset: 0; z-index: 3; pointer-events: none; }
.inner-stars span {
  position: absolute; border-radius: 999px; background: rgba(255, 242, 214, 0.88);
  box-shadow: 0 0 6px rgba(255, 233, 190, 0.7), 0 0 14px rgba(255, 210, 150, 0.32);
  animation: star-shine ease-in-out infinite alternate;
}

.inner-stars span.poly-star {
  border-radius: 2px;
  transform: rotate(45deg);
  clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
}

.sun-core { position: absolute; z-index: 8; top: 43%; left: 50%; width: 5.8%; aspect-ratio: 1; border-radius: 999px; background: #ffdda3;
  box-shadow: 0 0 16px rgba(255,221,163,1), 0 0 52px rgba(255,194,116,0.46), 0 0 110px rgba(187,118,84,0.26);
  transform: translate(-50%, -50%); animation: sun-pulse 4.8s ease-in-out infinite; }
.sun-halo { position: absolute; z-index: 7; top: 43%; left: 50%; border-radius: 999px; transform: translate(-50%, -50%); }
.halo-large { width: 34%; aspect-ratio: 1; background: radial-gradient(circle, rgba(255,218,158,0.18), transparent 68%); filter: blur(10px); }
.halo-small { width: 18%; aspect-ratio: 1; background: radial-gradient(circle, rgba(255,218,158,0.24), transparent 70%); filter: blur(6px); }

.cloud-band { position: absolute; left: -20%; right: -20%; z-index: 5; height: 10%; border-radius: 999px; background: linear-gradient(90deg, transparent, rgba(255,192,128,0.08), rgba(154,100,174,0.1), transparent); filter: blur(10px); }
.cloud-band-a { top: 48%; } .cloud-band-b { top: 57%; opacity: .72; } .cloud-band-c { top: 66%; opacity: .52; }
.light-ray { position: absolute; z-index: 6; height: 1px; width: 24%; background: linear-gradient(90deg, transparent, rgba(255,220,160,0.22), transparent); }
.ray-a { top: 50%; left: 27%; } .ray-b { top: 58%; right: 23%; } .ray-c { top: 64%; left: 40%; width: 18%; }

.mountain { position: absolute; left: -12%; right: -12%; bottom: 0; clip-path: polygon(0 68%,8% 50%,18% 62%,28% 33%,41% 60%,50% 40%,61% 64%,73% 35%,87% 58%,100% 43%,100% 100%,0 100%); }
.mountain-back { z-index: 9; height: 51%; background: rgba(59,46,66,.62); transform: translateY(-11%); }
.mountain-mid { z-index: 10; height: 46%; background: rgba(22,24,46,.86); transform: translateY(3%); }
.mountain-near { z-index: 11; height: 40%; background: rgba(7,12,28,.96); transform: translateY(15%); }
.mountain-front { z-index: 12; height: 33%; background: rgba(2,6,14,.99); transform: translateY(26%); }

.valley-light { position: absolute; left: 8%; right: 8%; z-index: 13; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,196,128,.2), transparent); filter: blur(.6px); }
.valley-light-a { top: 68%; } .valley-light-b { top: 76%; opacity: .62; }
.inner-fog { position: absolute; left: 6%; right: 6%; z-index: 14; height: 12%; border-radius: 999px; background: linear-gradient(90deg, transparent, rgba(255,202,142,.075), rgba(158,118,178,.06), transparent); filter: blur(10px); }
.fog-a { top: 63%; } .fog-b { top: 71%; opacity: .72; } .fog-c { top: 79%; opacity: .45; }
.circle-depth { position: absolute; inset: 0; z-index: 20; border-radius: inherit; background: radial-gradient(circle at 50% 48%, transparent 38%, rgba(0,0,0,.28) 72%, rgba(0,0,0,.72) 100%); }
.circle-grain { position: absolute; inset: 0; z-index: 21; border-radius: inherit; opacity: .13; }

@keyframes world-breathe { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-5px) scale(1.008)} }
@keyframes aurora-a { from{transform:translate3d(-3%,-1%,0)} to{transform:translate3d(4%,2%,0) scale(1.08)} }
@keyframes aurora-b { from{transform:translate3d(4%,1%,0)} to{transform:translate3d(-4%,-2%,0) scale(1.1)} }
@keyframes aurora-c { from{transform:translate3d(-2%,2%,0)} to{transform:translate3d(2%,-1%,0) scale(1.12)} }
@keyframes star-shine {
  0% { opacity: .36; filter: brightness(.9); }
  50% { opacity: .78; filter: brightness(1.15); }
  100% { opacity: .52; filter: brightness(1); }
}
@keyframes sun-pulse { 0%,100%{transform:translate(-50%,-50%) scale(.95)} 50%{transform:translate(-50%,-50%) scale(1.14)} }

